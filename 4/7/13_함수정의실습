//함수 정의실습
function sub(a, b) {
  return a - b;
}
function add(a, b) {
  return a + b;
}
function calc2(n1, n2, fn) {
  //dosomething (backend)
  return fn(n1, n2);
}
let result = calc2(5, 6, add);
result = calc2(5, 6, (n1, n2) => {
  console.log(n1 + n2);
  return n1 + n2;
});
result = calc2(8, 4, (n1, n2) => n1 - n2);

result = calc2(1, 4, function (n1, n2) {
  return n1 * n2;
});
